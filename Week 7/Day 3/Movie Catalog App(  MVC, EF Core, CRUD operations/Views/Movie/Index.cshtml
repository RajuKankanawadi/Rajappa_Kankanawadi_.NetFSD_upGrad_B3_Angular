@model IEnumerable<WebApplication6.Models.Movie>

<div class="container mt-4">
    
    <h2 class="text-primary">Movie List</h2> <br />
        <a asp-action="Create" class="btn btn-success">Add Movie</a> 
    </div>
<br />
<br />

    <table class="table table-bordered">
        <thead class=" table table-bordered table-striped">
            <tr>
                <th>Title</th>
                <th>Genre</th>
                <th>Release Date</th>
                <th>Price</th>
                <th>Rating</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Genre</td>
                    <td>@item.ReleaseDate.ToShortDateString()</td>
                    <td>@item.Price</td>
                    <td>@item.Rating</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
