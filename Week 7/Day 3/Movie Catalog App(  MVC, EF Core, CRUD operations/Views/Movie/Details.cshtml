@model WebApplication6.Models.Movie

<div class="container mt-4">
    <div class="card shadow p-4">
        <h2 class="text-info mb-4">Movie Details</h2>

        <table class="table table-bordered">
            <tr>
                <th>Title</th>
                <td>@Model.Title</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>@Model.Genre</td>
            </tr>
            <tr>
                <th>Release Date</th>
                <td>@Model.ReleaseDate.ToShortDateString()</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>@Model.Price</td>
            </tr>
            <tr>
                <th>Rating</th>
                <td>@Model.Rating</td>
            </tr>
        </table>

        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>