@model WebApplication5.Models.ContactInfo

        <h2 class="text-primary mb-4">Add Contact</h2>

        <form asp-action="AddContact" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Contact Id</label>
                    <input asp-for="ContactId" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Company Name</label>
                    <input asp-for="CompanyName" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Email Id</label>
                    <input asp-for="EmailId" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Mobile Number</label>
                    <input asp-for="MobileNo" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Designation</label>
                <input asp-for="Designation" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success">Save Contact</button>
            <a asp-action="ShowContacts" class="btn btn-secondary ms-2">Back</a>
        </form>
   