@model List<WebApplication5.Models.ContactInfo>


        <h2 class="text-primary mb-4" >All Contacts</h2>
        <a asp-action="AddContact" class="btn btn-success">Add New Contact</a>
   <br /><br />

    <div class="card shadow p-3">
        <table class="table table-bordered">
            <thead class="table-bordered">
                <tr>
                    <th>Id</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Company</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Designation</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ContactId</td>
                        <td>@item.FirstName</td>
                        <td>@item.LastName</td>
                        <td>@item.CompanyName</td>
                        <td>@item.EmailId</td>
                        <td>@item.MobileNo</td>
                        <td>@item.Designation</td>
                        <td>
                            <a asp-action="GetContactById" asp-route-id="@item.ContactId" class="btn btn-primary">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>