@model WebApplication10.Models.ContactInfo

<h2>Add Contact</h2>

<form asp-action="AddContact" method="post">
    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="EmailId" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Mobile</label>
        <input asp-for="MobileNo" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Designation</label>
        <input asp-for="Designation" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Company</label>
        <select asp-for="CompanyId" asp-items="ViewBag.Companies" class="form-control">
            <option value="">Select Company</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Department</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control">
            <option value="">Select Department</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>
</form>