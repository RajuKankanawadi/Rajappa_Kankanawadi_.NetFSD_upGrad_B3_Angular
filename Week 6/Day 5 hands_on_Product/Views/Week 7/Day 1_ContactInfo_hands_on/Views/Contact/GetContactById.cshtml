@model WebApplication2.Models.ContactInfo

<h2>Contact Details</h2>

@if (Model != null)
{
    <table class="table table-bordered">
        <tr>
            <th>Contact Id</th>
            <td>@Model.ContactId</td>
        </tr>
        <tr>
            <th>First Name</th>
            <td>@Model.FirstName</td>
        </tr>
        <tr>
            <th>Last Name</th>
            <td>@Model.LastName</td>
        </tr>
        <tr>
            <th>Company Name</th>
            <td>@Model.CompanyName</td>
        </tr>
        <tr>
            <th>Email Id</th>
            <td>@Model.EmailId</td>
        </tr>
        <tr>
            <th>Mobile No</th>
            <td>@Model.MobileNo</td>
        </tr>
        <tr>
            <th>Designation</th>
            <td>@Model.Designation</td>
        </tr>
    </table>
}
else
{
    <h3>No Contact Found</h3>
}

<a asp-action="ShowContacts" class="btn btn-primary">Back to Contact List</a>
