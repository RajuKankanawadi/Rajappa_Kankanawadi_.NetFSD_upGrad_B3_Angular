@model List<WebApplication2.Models.ContactInfo>

<h2>All Contacts</h2>

<p>
    <a asp-action="AddContact" class="btn btn-primary">Add New Contact</a>
</p>

<form asp-action="GetContactById" method="get">
    <label>Enter Contact Id:</label>
    <input type="number" name="id" required />
    <button type="submit" class="btn btn-success">Search</button>
</form>

<br />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Contact Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Company Name</th>
            <th>Email Id</th>
            <th>Mobile No</th>
            <th>Designation</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ContactId</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.CompanyName</td>
                <td>@item.EmailId</td>
                <td>@item.MobileNo</td>
                <td>@item.Designation</td>
            </tr>
        }
    </tbody>
</table>
